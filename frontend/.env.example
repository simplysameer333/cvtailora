NEXT_PUBLIC_API_URL=http://localhost:9000

# Set to true on localhost to skip all auth. Shows a floating tier switcher (free/plus/pro).
# Remove or set to false before deploying to production.
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# NextAuth — must match between instances
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=change-me-in-production

# Google OAuth (create at console.cloud.google.com — add redirect URI: NEXTAUTH_URL/api/auth/callback/google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
