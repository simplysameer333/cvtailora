# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
.next/
*.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Secrets — never commit files with real credentials ────────────────────────
.env
.env.local
.env.*.local
client_secret_*.json
# Allow example/template files and committed environment defaults (no secrets)
!.env.example
!.env.*.example
!.env.development
!.env.production
!.env.uat
.claude/

# ── Uploaded user files ───────────────────────────────────────────────────────
backend/uploads/
!backend/uploads/.gitkeep
backend/templates/uploads/*
!backend/templates/uploads/.gitkeep

# TypeScript incremental build state (churns on every typecheck)
*.tsbuildinfo
